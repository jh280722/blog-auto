{
  "manifest_version": 3,
  "name": "Tistory Auto Publisher",
  "version": "1.8.27",
  "description": "\ud2f0\uc2a4\ud1a0\ub9ac \ube14\ub85c\uadf8 \uc790\ub3d9 \ubc1c\ud589 \ud655\uc7a5 \ud504\ub85c\uadf8\ub7a8 - \uc2ec\ud50c UI + \uc678\ubd80 API \uc9c0\uc6d0",
  "permissions": [
    "activeTab",
    "storage",
    "scripting",
    "tabs",
    "alarms"
  ],
  "host_permissions": [
    "*://*.tistory.com/*",
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background/service-worker.js",
    "type": "module"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "content_scripts": [
    {
      "matches": [
        "*://*.tistory.com/manage/newpost*",
        "*://*.tistory.com/manage/post/*"
      ],
      "js": [
        "content/selectors.js",
        "utils/image-handler.js",
        "utils/captcha-challenge.js",
        "utils/draft-snapshot.js",
        "content/tistory.js"
      ],
      "run_at": "document_start"
    }
  ],
  "externally_connectable": {
    "matches": [
      "http://localhost/*",
      "http://127.0.0.1/*",
      "http://127.0.0.1:8765/*"
    ]
  },
  "web_accessible_resources": [
    {
      "resources": [
        "icons/*"
      ],
      "matches": [
        "*://*.tistory.com/*"
      ]
    }
  ]
}